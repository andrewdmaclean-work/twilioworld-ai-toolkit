#!/usr/bin/env bash
#
# toolkit — TwilioWorld Agentic Coding Toolkit entry point.
# Bootstraps bun if needed, then launches the TUI.
#
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="$ROOT/.toolkit"
TOOLCHAINS_DIR="$CONFIG_DIR/toolchains"
BUN_INSTALL="$TOOLCHAINS_DIR/bun"
BUN_BIN="$BUN_INSTALL/bin/bun"
NODE_VERSION="${TOOLKIT_NODE_VERSION:-22.19.0}"
NODE_HOME="$TOOLCHAINS_DIR/node-v22"
NODE_BIN="$NODE_HOME/bin/node"
NPM_PREFIX="$CONFIG_DIR/npm-global"
export BUN_INSTALL
export npm_config_prefix="$NPM_PREFIX"
export NPM_CONFIG_PREFIX="$NPM_PREFIX"
export PATH="$NPM_PREFIX/bin:$BUN_INSTALL/bin:$NODE_HOME/bin:$PATH"

node_ok() {
  command -v node >/dev/null 2>&1 || return 1
  local v major rest minor
  v="$(node --version | sed 's/^v//')"
  major="${v%%.*}"; rest="${v#*.}"; minor="${rest%%.*}"
  (( major > 22 || (major == 22 && minor >= 19) ))
}

doctor_check() {
  local desc="$1"; shift
  if "$@" >/dev/null 2>&1; then
    printf 'OK   %s\n' "$desc"
    return 0
  fi
  printf 'MISS %s\n' "$desc"
  return 1
}

doctor_info() {
  local desc="$1"; shift
  if "$@" >/dev/null 2>&1; then
    printf 'OK   %s\n' "$desc"
  else
    printf 'INFO %s not installed yet\n' "$desc"
  fi
}

run_doctor() {
  local fail=0
  echo "TwilioWorld Toolkit Doctor"
  echo "repo: $ROOT"
  case "${MODEL_REASONING:-off}" in
    on|auto) echo "model reasoning: ${MODEL_REASONING}" ;;
    *) echo "model reasoning: off" ;;
  esac
  echo

  doctor_check "interactive terminal" test -t 0 || fail=1
  doctor_check "UTF-8 locale" bash -c 'case "${LC_ALL:-${LANG:-}}" in *UTF-8*|*utf8*|*UTF8*) exit 0 ;; *) exit 1 ;; esac' || fail=1
  doctor_check "git on PATH" command -v git || fail=1
  doctor_check "curl on PATH" command -v curl || fail=1
  doctor_check "project-local bun" test -x "$BUN_BIN" || fail=1
  doctor_check "project-local Node >= 22.19.0" node_ok || fail=1
  doctor_check "Twilio skills submodule populated" test -f "$ROOT/vendor/twilio-ai/skills/README.md" || fail=1
  doctor_check "repo writable" test -w "$ROOT" || fail=1

  if command -v df >/dev/null 2>&1; then
    local available_kb
    available_kb="$(df -Pk "$ROOT" | awk 'NR==2 {print $4}')"
    if [[ "${available_kb:-0}" =~ ^[0-9]+$ && "$available_kb" -ge 6291456 ]]; then
      printf 'OK   disk space for local model (%s GB free)\n' "$((available_kb / 1024 / 1024))"
    else
      printf 'MISS disk space for local model (need roughly 6 GB free)\n'
      fail=1
    fi
  fi

  doctor_info "llamafile runtime" test -x "$ROOT/tools/llamafile"
  doctor_info "local model file" bash -c "ls '$ROOT/models/'*.gguf >/dev/null 2>&1"
  doctor_info "toolkit-local Twilio CLI" test -x "$NPM_PREFIX/bin/twilio"
  printf 'INFO toolkit Twilio CLI home: %s\n' "$CONFIG_DIR/twilio-cli-home"

  echo
  if [[ "$fail" -eq 0 ]]; then
    echo "Doctor passed. Run ./toolkit to open the dashboard."
  else
    echo "Doctor found missing prerequisites. Run ./toolkit and Setup can install the supported pieces."
    echo "If the submodule is missing, run: git submodule update --init --recursive"
  fi
  return "$fail"
}

open_in_terminal() {
  local app="$1"
  local toolkit_path
  toolkit_path="$(printf '%q' "$ROOT/toolkit")"

  case "$app" in
    iTerm)
      osascript <<APPLESCRIPT
tell application "iTerm"
  activate
  create window with default profile command "$ROOT/toolkit"
end tell
APPLESCRIPT
      ;;
    Ghostty)
      open -a Ghostty --args --command="$ROOT/toolkit"
      ;;
    Warp)
      open -a Warp "$ROOT"
      # Warp doesn't support passing an arbitrary command on open, so just
      # open it at the repo root and let the user run ./toolkit from there.
      echo "Warp opened at $ROOT — run ./toolkit to launch."
      ;;
    Hyper)
      open -a Hyper "$ROOT"
      echo "Hyper opened at $ROOT — run ./toolkit to launch."
      ;;
    Alacritty)
      # Alacritty is not AppleScript-able; launch via open with --command
      open -a Alacritty --args --command "$ROOT/toolkit"
      ;;
    Terminal|*)
      # Terminal.app via a .command file (most reliable across macOS versions)
      local script
      script="$(mktemp "${TMPDIR:-/tmp}/twilioworld-open.XXXXXX.command")"
      printf '#!/bin/sh\ncd %s\nexec %s\n' "$ROOT" "$ROOT/toolkit" > "$script"
      chmod +x "$script"
      open -a Terminal "$script"
      ;;
  esac
}

case "${1:-}" in
  doctor|--doctor)
    run_doctor
    exit $?
    ;;
  --iterm)
    open_in_terminal "iTerm"
    exit 0
    ;;
  --ghostty)
    open_in_terminal "Ghostty"
    exit 0
    ;;
  --warp)
    open_in_terminal "Warp"
    exit 0
    ;;
  --hyper)
    open_in_terminal "Hyper"
    exit 0
    ;;
  --alacritty)
    open_in_terminal "Alacritty"
    exit 0
    ;;
  --terminal)
    open_in_terminal "Terminal"
    exit 0
    ;;
  -h|--help)
    echo "Usage: ./toolkit [options]"
    echo "  (no args)    launch the TUI in this terminal"
    echo "  --iterm      open in a new iTerm2 window"
    echo "  --ghostty    open in a new Ghostty window"
    echo "  --warp       open in a new Warp window"
    echo "  --hyper      open in a new Hyper window"
    echo "  --alacritty  open in a new Alacritty window"
    echo "  --terminal   open in a new Terminal.app window"
    echo "  --doctor     check prerequisites"
    exit 0
    ;;
esac

# Security audit E-8/H-4: refuse root before doing anything — installing
# bun, running `bun install`, and downloading multi-GB model files as
# root would leave root-owned files under $ROOT that a normal-user run
# can no longer touch. index.ts checks this again once the TUI itself
# starts, but that's after bun/bun-install may already have run as root.
if [[ "${TOOLKIT_TUI_SMOKE:-}" != "1" && "${EUID:-$(id -u)}" -eq 0 ]]; then
  echo "TwilioWorld Agentic Coding Toolkit should not be run as root." >&2
  echo "Re-run ./toolkit as your normal user — sudo here would root-own your model files and config." >&2
  exit 2
fi

platform_arch() {
  local os arch
  os="$(uname -s)"
  arch="$(uname -m)"
  case "$os:$arch" in
    Darwin:arm64|Darwin:aarch64) echo "bun-darwin-aarch64 darwin-arm64" ;;
    Darwin:x86_64|Darwin:amd64)  echo "bun-darwin-x64 darwin-x64" ;;
    Linux:arm64|Linux:aarch64)   echo "bun-linux-aarch64 linux-arm64" ;;
    Linux:x86_64|Linux:amd64)    echo "bun-linux-x64 linux-x64" ;;
    *) echo "unsupported unsupported" ;;
  esac
}

ensure_project_bun() {
  [[ -x "$BUN_BIN" ]] && return 0
  command -v curl >/dev/null 2>&1 || { echo "curl is required to install project-local Bun." >&2; return 1; }
  command -v unzip >/dev/null 2>&1 || { echo "unzip is required to install project-local Bun." >&2; return 1; }

  local bun_target node_target tmp zip
  read -r bun_target node_target < <(platform_arch)
  [[ "$bun_target" != "unsupported" ]] || { echo "Unsupported platform for Bun: $(uname -s) $(uname -m)" >&2; return 1; }

  echo "Installing project-local Bun into $BUN_INSTALL..."
  tmp="$(mktemp -d "${TMPDIR:-/tmp}/twilioworld-bun.XXXXXX")"
  zip="$tmp/bun.zip"
  curl -fsSL "https://github.com/oven-sh/bun/releases/latest/download/${bun_target}.zip" -o "$zip" \
    || { echo "Bun download failed." >&2; rm -rf "$tmp"; return 1; }
  unzip -q "$zip" -d "$tmp" \
    || { echo "Bun extraction failed." >&2; rm -rf "$tmp"; return 1; }
  mkdir -p "$BUN_INSTALL/bin"
  mv "$tmp/$bun_target/bun" "$BUN_BIN" \
    || { echo "Could not install Bun into $BUN_BIN." >&2; rm -rf "$tmp"; return 1; }
  chmod +x "$BUN_BIN"
  rm -rf "$tmp"
}

ensure_project_node() {
  [[ -x "$NODE_BIN" ]] && node_ok && return 0
  command -v curl >/dev/null 2>&1 || { echo "curl is required to install project-local Node." >&2; return 1; }
  command -v tar >/dev/null 2>&1 || { echo "tar is required to install project-local Node." >&2; return 1; }

  local bun_target node_target tmp archive
  read -r bun_target node_target < <(platform_arch)
  [[ "$node_target" != "unsupported" ]] || { echo "Unsupported platform for Node: $(uname -s) $(uname -m)" >&2; return 1; }

  echo "Installing project-local Node $NODE_VERSION into $NODE_HOME..."
  tmp="$(mktemp -d "${TMPDIR:-/tmp}/twilioworld-node.XXXXXX")"
  archive="$tmp/node.tar.xz"
  curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-${node_target}.tar.xz" -o "$archive" \
    || { echo "Node download failed." >&2; rm -rf "$tmp"; return 1; }
  rm -rf "$NODE_HOME"
  mkdir -p "$NODE_HOME"
  tar -xJf "$archive" -C "$NODE_HOME" --strip-components=1 \
    || { echo "Node extraction failed." >&2; rm -rf "$tmp"; return 1; }
  rm -rf "$tmp"
  node_ok || { echo "Project-local Node is not new enough: $("$NODE_BIN" --version 2>/dev/null || echo not found)" >&2; return 1; }
}

ensure_project_bun || exit 1
if [[ "${TOOLKIT_TUI_SMOKE:-}" != "1" ]]; then
  ensure_project_node || exit 2
fi

cd "$ROOT/tui"
[[ -d node_modules ]] || "$BUN_BIN" install

exec "$BUN_BIN" run src/index.ts "$@"
