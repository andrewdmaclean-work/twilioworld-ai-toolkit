#!/usr/bin/env bash
#
# toolkit — TwilioWorld Agentic Coding Toolkit entry point.
# Bootstraps bun if needed, then launches the TUI.
#
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Security audit E-8/H-4: refuse root before doing anything — installing
# bun, running `bun install`, and downloading multi-GB model files as
# root would leave root-owned files under $ROOT that a normal-user run
# can no longer touch. index.ts checks this again once the TUI itself
# starts, but that's after bun/bun-install may already have run as root.
if [[ "${TOOLKIT_TUI_SMOKE:-}" != "1" && "${EUID:-$(id -u)}" -eq 0 ]]; then
  echo "TwilioWorld Agentic Coding Toolkit should not be run as root." >&2
  echo "Re-run ./toolkit as your normal user — sudo here would root-own your model files and config." >&2
  exit 2
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "Installing bun (needed for the TUI)..."
  if command -v brew >/dev/null 2>&1; then
    brew install bun || { echo "brew install bun failed. Install manually: https://bun.sh"; exit 1; }
  else
    curl -fsSL https://bun.sh/install | bash || { echo "bun install failed. Install manually: https://bun.sh"; exit 1; }
  fi
fi

cd "$ROOT/tui"
[[ -d node_modules ]] || bun install

# ── Node >= 22.19.0 requirement ──────────────────────────────────────────
# The TUI (and Pi) need a modern Node on PATH. bun above is only the TUI
# runtime; several agent/tooling paths still shell out to `node`/`npm`.
# If Node is missing or too old we offer to install it via nvm (no sudo,
# no system-wide change — it lives in ~/.nvm and is the most portable
# option across macOS/Linux). We prompt first because installing nvm
# writes to the user's shell rc files.
node_ok() {
  command -v node >/dev/null 2>&1 || return 1
  local v major rest minor
  v="$(node --version | sed 's/^v//')"
  major="${v%%.*}"; rest="${v#*.}"; minor="${rest%%.*}"
  (( major > 22 || (major == 22 && minor >= 19) ))
}

# Load nvm into THIS shell if it's already installed but not sourced
# (non-interactive shells don't run the rc lines that define `nvm`).
load_nvm() {
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  # shellcheck disable=SC1091
  [[ -s "$NVM_DIR/nvm.sh" ]] && . "$NVM_DIR/nvm.sh" >/dev/null 2>&1
  command -v nvm >/dev/null 2>&1
}

install_node_via_nvm() {
  echo "Installing nvm + Node 22 (this writes to ~/.nvm and your shell profile)..." >&2
  if ! load_nvm; then
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash \
      || { echo "nvm install failed. Install Node 22 manually: https://nodejs.org" >&2; return 1; }
    load_nvm || { echo "nvm installed but could not be loaded into this shell. Open a new terminal and re-run ./toolkit." >&2; return 1; }
  fi
  nvm install 22 || { echo "nvm install 22 failed." >&2; return 1; }
  nvm use 22 >/dev/null 2>&1 || return 1
  node_ok
}

if [[ "${TOOLKIT_TUI_SMOKE:-}" != "1" ]] && ! node_ok; then
  # Maybe nvm already has a good Node, just not loaded into this shell.
  if load_nvm && nvm use 22 >/dev/null 2>&1 && node_ok; then
    :  # good — nvm's Node 22 is now active for this run
  else
    current="$(command -v node >/dev/null 2>&1 && node --version || echo 'not found')"
    echo "TwilioWorld Agentic Coding Toolkit requires Node >= 22.19.0 on PATH (current: ${current})." >&2
    if [[ -t 0 ]]; then
      printf "Install Node 22 now via nvm? [y/N] " >&2
      read -r reply
    else
      reply="n"
    fi
    if [[ "$reply" =~ ^[Yy]$ ]] && install_node_via_nvm; then
      echo "Node $(node --version) is now active for this session." >&2
    else
      echo "Skipping auto-install. Install Node 22 and re-run:  nvm install 22 && nvm use 22" >&2
      exit 2
    fi
  fi
fi

exec bun run src/index.ts "$@"
